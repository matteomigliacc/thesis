@book{zieglerResearchHandbookGeneral2022,
  title = {Research Handbook on General Principles in {{EU}} Law: Constructing Legal Orders in {{Europe}}},
  shorttitle = {Research Handbook on General Principles in {{EU}} Law},
  editor = {Ziegler, Katja S. and Neuvonen, Päivi Johanna and Moreno Lax, Violeta},
  date = {2022-04-19},
  series = {Research Handbooks in {{European}} Law},
  publisher = {Edward Elgar Publishing},
  location = {Cheltenham, UK ; Northampton, MA, USA},
  doi = {https://doi-org.utrechtuniversity.idm.oclc.org/10.4337/9781784712389},
  url = {https://www-elgaronline-com.utrechtuniversity.idm.oclc.org/edcollbook/edcoll/9781784712372/9781784712372.xml},
  abstract = {"This innovative Research Handbook explores the judicial and scholarly approaches to, and theories surrounding, general principles in the EU legal order against the backdrop of considerable uncertainty about the concept. It does so by analysing a diverse range of general principles in discrete areas of EU law ('zooming in') and external, wider perspectives on the notion of a general principle of law from international law, comparative law, and legal theory ('zooming out'). Rather than arguing for a single closed definition of what a general principle of law in the EU legal order must look like, this Research Handbook identifies conceptual, theoretical, and legal parameters within which the doctrine of general principles can be meaningfully discussed and contested in EU law. The different analytical layers built into this Handbook shed light on whether general principles are defined by the different contexts in which they apply; whether general principles are in practice leading to more coherence between different areas of EU law; and what challenges they create for the EU legal order. Chapters thus contribute to a more refined methodological and doctrinal understanding of general principles in the EU legal order. Opening up new spaces to critically reflect on the concept, role, significance, and limitations of general principles, the Research Handbook on General Principles in EU Law will be a key resource for scholars and students of European law, politics, and theory of integration and internationalisation"--},
  isbn = {978-1-78471-237-2},
  langid = {american},
  pagetotal = {642},
  keywords = {European Union countries,Law,Philosophy}
}
