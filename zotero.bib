@online{hofmannProceduresMatterWhat2023,
  type = {SSRN Scholarly Paper},
  title = {Procedures {{Matter}} – {{What}} to {{Address}} in {{GDPR Reform}} and a New {{GDPR Procedural Regulation}}},
  author = {Hofmann, Herwig C.H. and Mustert, Lisette},
  date = {2023-05-31},
  number = {4492662},
  eprint = {4492662},
  eprinttype = {Social Science Research Network},
  location = {Rochester, NY},
  doi = {10.2139/ssrn.4492662},
  url = {https://papers.ssrn.com/abstract=4492662},
  urldate = {2026-02-10},
  abstract = {This contribution is part of the "EU Law Live Symposium on the 5th Anniversary of the GDPR".To observers of EU administrative law, the GDPR was –from its conception– (in-)famous for the complexity of its system of composite enforcement procedures (see here). The reality confirmed the concerns. The first five years of experience show that some procedures can appear interminably long and slow (the ten years of administrative procedures following the original Schrems complaint of 2013 to the Irish Data Protection Commissioner being one example). In view of concerns about procedural shortcomings, the European Commission has announced work on a new GDPR procedural regulation. But what are the main take-aways from experiences with GDPR enforcement that should be reflected in a GDPR procedural regulation and possibly GDPR reform? Three big topics come to mind: First, the nature of individual enforcement procedures on the basis of individual complaints. Second, the distribution of enforcement powers between national and European bodies. Third, assessing the procedure leading to third country adequacy decision.},
  langid = {english},
  pubstate = {prepublished},
  keywords = {Herwig C.H. Hofmann,Lisette Mustert,Procedures Matter – What to Address in GDPR Reform and a new GDPR Procedural Regulation,SSRN},
  file = {/Users/matteomigliaccio/Library/Mobile Documents/iCloud~md~obsidian/Documents/Matteo's Notebook/00 - Thesis Trajectory/Literature/PDFs/Hofmann and Mustert - 2023 - Procedures Matter – What to Address in GDPR Reform and a new GDPR Procedural Regulation.pdf}
}

